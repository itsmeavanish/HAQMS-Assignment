NODE_ENV=production
PORT=5000
# Strong secret from your secrets manager (do NOT commit)
JWT_SECRET=replace_with_long_random_value_from_vault
# Production Postgres (example with ssl enforced)
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>?schema=public&sslmode=require
# Optional: shadow DB for Prisma migrations in CI
# SHADOW_DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<shadow_db>?schema=public&sslmode=require
